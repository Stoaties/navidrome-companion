# Copy to .env and adjust before the first `docker compose up`.
# These only take effect on first boot (when the user database is empty).

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme

# Where downloaded music is stored on the host (point this at a USB drive if you
# like). Shared read-only with Navidrome and read by the e-ink status display.
# Defaults to ./music inside the project if unset.
MUSIC_PATH=./music
